{
  "name": "sofia-assistente",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=!@sofia/admin dev",
    "dev:admin": "pnpm --filter @sofia/admin dev",
    "build": "pnpm -r build",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "regen-docs": "tsx scripts/regen-docs.ts",
    "check-drift": "tsx scripts/check-drift.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "smoke": "tsx scripts/smoke.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "supabase/migrations/**/*.sql": [
      "pnpm regen-docs",
      "git add docs .agents/skills packages/db/src/types.generated.ts tests/contract"
    ]
  }
}
